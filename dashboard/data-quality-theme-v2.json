{
  "name": "Data Quality Monitor - Clean Pro",
  "dataColors": [
    "#10B981",
    "#F59E0B",
    "#EF4444",
    "#3B82F6",
    "#8B5CF6",
    "#06B6D4",
    "#EC4899",
    "#6366F1"
  ],
  "good": "#10B981",
  "neutral": "#F59E0B",
  "bad": "#EF4444",
  "maximum": "#10B981",
  "center": "#F59E0B",
  "minimum": "#EF4444",
  "foreground": "#111827",
  "foregroundNeutralSecondary": "#6B7280",
  "foregroundNeutralTertiary": "#9CA3AF",
  "background": "#F9FAFB",
  "backgroundLight": "#FFFFFF",
  "backgroundNeutral": "#E5E7EB",
  "tableAccent": "#3B82F6",

  "textClasses": {
    "title": {
      "fontFace": "Segoe UI Semibold",
      "fontSize": 11,
      "color": "#374151"
    },
    "header": {
      "fontFace": "Segoe UI Semibold",
      "fontSize": 10,
      "color": "#374151"
    },
    "label": {
      "fontFace": "Segoe UI",
      "fontSize": 9,
      "color": "#6B7280"
    },
    "callout": {
      "fontFace": "Segoe UI",
      "fontSize": 32,
      "color": "#111827"
    }
  },

  "visualStyles": {
    "page": {
      "*": {
        "background": [{
          "color": {"solid": {"color": "#F9FAFB"}},
          "transparency": 0
        }]
      }
    },

    "*": {
      "*": {
        "background": [{
          "show": true,
          "color": {"solid": {"color": "#FFFFFF"}},
          "transparency": 0
        }],
        "border": [{
          "show": true,
          "color": {"solid": {"color": "#E5E7EB"}},
          "radius": 8
        }],
        "dropShadow": [{
          "show": false
        }],
        "title": [{
          "show": true,
          "fontColor": {"solid": {"color": "#374151"}},
          "background": {"solid": {"color": "#FFFFFF"}},
          "fontSize": 11,
          "fontFamily": "Segoe UI Semibold",
          "alignment": "left"
        }],
        "visualHeader": [{
          "show": false
        }]
      }
    },

    "card": {
      "*": {
        "background": [{
          "show": true,
          "color": {"solid": {"color": "#FFFFFF"}},
          "transparency": 0
        }],
        "border": [{
          "show": true,
          "color": {"solid": {"color": "#E5E7EB"}},
          "radius": 12
        }],
        "dropShadow": [{
          "show": false
        }],
        "labels": [{
          "show": true,
          "color": {"solid": {"color": "#111827"}},
          "fontSize": 32,
          "fontFamily": "Segoe UI",
          "labelPrecision": 2
        }],
        "categoryLabels": [{
          "show": true,
          "color": {"solid": {"color": "#9CA3AF"}},
          "fontSize": 10,
          "fontFamily": "Segoe UI"
        }]
      }
    },

    "lineChart": {
      "*": {
        "background": [{
          "show": true,
          "color": {"solid": {"color": "#FFFFFF"}},
          "transparency": 0
        }],
        "border": [{
          "show": true,
          "color": {"solid": {"color": "#E5E7EB"}},
          "radius": 8
        }],
        "dropShadow": [{
          "show": false
        }],
        "dataPoint": [{
          "defaultColor": {"solid": {"color": "#10B981"}},
          "showAllDataPoints": true
        }],
        "lineStyles": [{
          "strokeWidth": 2,
          "showMarker": true,
          "markerSize": 5
        }],
        "categoryAxis": [{
          "show": true,
          "showAxisTitle": false,
          "labelColor": {"solid": {"color": "#9CA3AF"}},
          "fontSize": 9,
          "fontFamily": "Segoe UI"
        }],
        "valueAxis": [{
          "show": true,
          "showAxisTitle": false,
          "labelColor": {"solid": {"color": "#9CA3AF"}},
          "fontSize": 9,
          "fontFamily": "Segoe UI",
          "gridlineShow": true,
          "gridlineColor": {"solid": {"color": "#F3F4F6"}},
          "gridlineThickness": 1
        }]
      }
    },

    "donutChart": {
      "*": {
        "background": [{
          "show": true,
          "color": {"solid": {"color": "#FFFFFF"}},
          "transparency": 0
        }],
        "border": [{
          "show": true,
          "color": {"solid": {"color": "#E5E7EB"}},
          "radius": 8
        }],
        "dropShadow": [{
          "show": false
        }],
        "slices": [{
          "innerRadiusRatio": 65
        }],
        "labels": [{
          "show": true,
          "color": {"solid": {"color": "#6B7280"}},
          "fontSize": 9,
          "fontFamily": "Segoe UI"
        }],
        "legend": [{
          "show": true,
          "position": "Right",
          "fontSize": 9,
          "fontFamily": "Segoe UI",
          "labelColor": {"solid": {"color": "#6B7280"}}
        }]
      }
    },

    "pieChart": {
      "*": {
        "background": [{
          "show": true,
          "color": {"solid": {"color": "#FFFFFF"}},
          "transparency": 0
        }],
        "border": [{
          "show": true,
          "color": {"solid": {"color": "#E5E7EB"}},
          "radius": 8
        }],
        "dropShadow": [{
          "show": false
        }],
        "slices": [{
          "innerRadiusRatio": 65
        }]
      }
    },

    "barChart": {
      "*": {
        "background": [{
          "show": true,
          "color": {"solid": {"color": "#FFFFFF"}},
          "transparency": 0
        }],
        "border": [{
          "show": true,
          "color": {"solid": {"color": "#E5E7EB"}},
          "radius": 8
        }],
        "dropShadow": [{
          "show": false
        }],
        "dataPoint": [{
          "defaultColor": {"solid": {"color": "#10B981"}}
        }],
        "categoryAxis": [{
          "show": true,
          "showAxisTitle": false,
          "labelColor": {"solid": {"color": "#6B7280"}},
          "fontSize": 9,
          "fontFamily": "Segoe UI"
        }],
        "valueAxis": [{
          "show": true,
          "showAxisTitle": false,
          "labelColor": {"solid": {"color": "#9CA3AF"}},
          "fontSize": 9,
          "fontFamily": "Segoe UI",
          "gridlineShow": true,
          "gridlineColor": {"solid": {"color": "#F3F4F6"}},
          "gridlineThickness": 1
        }],
        "labels": [{
          "show": true,
          "color": {"solid": {"color": "#374151"}},
          "fontSize": 9,
          "fontFamily": "Segoe UI",
          "enableBackground": false
        }]
      }
    },

    "clusteredBarChart": {
      "*": {
        "background": [{
          "show": true,
          "color": {"solid": {"color": "#FFFFFF"}},
          "transparency": 0
        }],
        "border": [{
          "show": true,
          "color": {"solid": {"color": "#E5E7EB"}},
          "radius": 8
        }],
        "dropShadow": [{
          "show": false
        }],
        "dataPoint": [{
          "defaultColor": {"solid": {"color": "#10B981"}}
        }],
        "categoryAxis": [{
          "show": true,
          "showAxisTitle": false,
          "labelColor": {"solid": {"color": "#6B7280"}},
          "fontSize": 9,
          "fontFamily": "Segoe UI"
        }],
        "valueAxis": [{
          "show": true,
          "showAxisTitle": false,
          "labelColor": {"solid": {"color": "#9CA3AF"}},
          "fontSize": 9,
          "fontFamily": "Segoe UI",
          "gridlineShow": true,
          "gridlineColor": {"solid": {"color": "#F3F4F6"}},
          "gridlineThickness": 1
        }],
        "labels": [{
          "show": true,
          "color": {"solid": {"color": "#374151"}},
          "fontSize": 9,
          "fontFamily": "Segoe UI",
          "enableBackground": false
        }]
      }
    },

    "slicer": {
      "*": {
        "background": [{
          "show": true,
          "color": {"solid": {"color": "#FFFFFF"}},
          "transparency": 0
        }],
        "border": [{
          "show": true,
          "color": {"solid": {"color": "#E5E7EB"}},
          "radius": 8
        }],
        "dropShadow": [{
          "show": false
        }],
        "header": [{
          "show": true,
          "fontColor": {"solid": {"color": "#374151"}},
          "background": {"solid": {"color": "#FFFFFF"}},
          "fontSize": 10,
          "fontFamily": "Segoe UI Semibold"
        }],
        "items": [{
          "fontColor": {"solid": {"color": "#374151"}},
          "background": {"solid": {"color": "#F9FAFB"}},
          "fontSize": 9,
          "fontFamily": "Segoe UI"
        }],
        "selection": [{
          "selectAllCheckboxEnabled": true,
          "singleSelect": false
        }]
      }
    },

    "tableEx": {
      "*": {
        "background": [{
          "show": true,
          "color": {"solid": {"color": "#FFFFFF"}},
          "transparency": 0
        }],
        "border": [{
          "show": true,
          "color": {"solid": {"color": "#E5E7EB"}},
          "radius": 8
        }],
        "dropShadow": [{
          "show": false
        }],
        "grid": [{
          "gridVertical": false,
          "gridHorizontal": true,
          "gridHorizontalColor": {"solid": {"color": "#F3F4F6"}},
          "gridHorizontalWeight": 1,
          "rowPadding": 8,
          "outlineColor": {"solid": {"color": "#E5E7EB"}},
          "outlineWeight": 1
        }],
        "columnHeaders": [{
          "fontColor": {"solid": {"color": "#374151"}},
          "backColor": {"solid": {"color": "#F9FAFB"}},
          "fontSize": 10,
          "fontFamily": "Segoe UI Semibold",
          "alignment": "Left",
          "wordWrap": false
        }],
        "values": [{
          "fontColor": {"solid": {"color": "#6B7280"}},
          "backColor": {"solid": {"color": "#FFFFFF"}},
          "fontSize": 9,
          "fontFamily": "Segoe UI",
          "wordWrap": false
        }],
        "total": [{
          "fontColor": {"solid": {"color": "#111827"}},
          "backColor": {"solid": {"color": "#F3F4F6"}},
          "fontSize": 10,
          "fontFamily": "Segoe UI Semibold"
        }]
      }
    },

    "textbox": {
      "*": {
        "background": [{
          "show": false
        }],
        "border": [{
          "show": false
        }],
        "dropShadow": [{
          "show": false
        }]
      }
    },

    "shape": {
      "*": {
        "background": [{
          "show": false
        }],
        "border": [{
          "show": false
        }],
        "dropShadow": [{
          "show": false
        }]
      }
    },

    "actionButton": {
      "*": {
        "background": [{
          "show": true,
          "color": {"solid": {"color": "#3B82F6"}},
          "transparency": 0
        }],
        "border": [{
          "show": false
        }],
        "dropShadow": [{
          "show": false
        }],
        "text": [{
          "fontColor": {"solid": {"color": "#FFFFFF"}},
          "fontSize": 10,
          "fontFamily": "Segoe UI Semibold"
        }]
      }
    }
  }
}
